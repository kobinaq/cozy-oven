# Public site URL (used for sitemap, OG, canonicals)
NEXT_PUBLIC_SITE_URL=https://cozyoven.store

# Backend API (browser SSR fetches + server proxy fallback)
NEXT_PUBLIC_API_BASE_URL=https://cozy-oven-bakery-backend.onrender.com

# Server-only: preferred backend URL for BFF proxy / auth routes
API_BASE_URL=https://cozy-oven-bakery-backend.onrender.com

# Must match backend ACCESS_TOKEN_SECRET (server-only — never expose as NEXT_PUBLIC_)
AUTH_JWT_SECRET=replace-with-same-secret-as-backend-ACCESS_TOKEN_SECRET
